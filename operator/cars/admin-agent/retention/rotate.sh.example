#!/usr/bin/env bash
# rotate.sh.example — placeholder outline for the 90-day retention rotation.
#
# DO NOT run this file as-is. Copy it to rotate.sh, adapt the paths to
# your deployment, and schedule via systemd timer or cron.
#
# This script implements the policy described in
# operator/cars/admin-agent/retention/README.md:
#   - purge any plaintext files (should be zero — agent never writes them)
#   - purge resolved decision files older than 90 days
#   - emit a structured log line per file purged
#
# Outline only. Fill in the bodies before deploying.

set -euo pipefail

